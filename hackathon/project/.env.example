# Example environment variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# ═══════════════════════════════════════════════════════════════
# CAW Mode
# ═══════════════════════════════════════════════════════════════

# mock = offline simulation (no SDK required, default)
# real = connect to Cobo Agentic Wallet service (requires SDK + API key)
CAW_MODE=mock

# ═══════════════════════════════════════════════════════════════
# Cobo CAW Real Mode Credentials
# Only needed when CAW_MODE=real
# ═══════════════════════════════════════════════════════════════

# Dev environment: https://api-core.agenticwallet.dev.cobo.com
# Production:     https://api.agenticwallet.cobo.com
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com

# Get these from: caw wallet current --show-api-key
AGENT_WALLET_API_KEY=your_caw_api_key_here
AGENT_WALLET_WALLET_ID=your_wallet_uuid_here

# ═══════════════════════════════════════════════════════════════
# Chain & Token Defaults
# ═══════════════════════════════════════════════════════════════

CAW_DEFAULT_CHAIN=BASE_ETH
CAW_DEFAULT_TOKEN=BASE_USDC

# ═══════════════════════════════════════════════════════════════
# Vendor On-Chain Addresses (real mode)
# Replace with actual addresses for your vendors
# ═══════════════════════════════════════════════════════════════

VENDOR_OPENAI_ADDR=0x0000000000000000000000000000000000000000
VENDOR_MIDJOURNEY_ADDR=0x0000000000000000000000000000000000000000
VENDOR_UNSPLASH_ADDR=0x0000000000000000000000000000000000000000
VENDOR_GOOGLE_ADS_ADDR=0x0000000000000000000000000000000000000000
VENDOR_TWITTER_ADS_ADDR=0x0000000000000000000000000000000000000000
VENDOR_DESIGNER_PH_ADDR=0x0000000000000000000000000000000000000000
VENDOR_TRANSLATOR_VN_ADDR=0x0000000000000000000000000000000000000000
VENDOR_AWS_ADDR=0x0000000000000000000000000000000000000000
VENDOR_VERCEL_ADDR=0x0000000000000000000000000000000000000000

# ═══════════════════════════════════════════════════════════════
# Backend API (for React frontend)
# ═══════════════════════════════════════════════════════════════

# Port for FastAPI backend
BACKEND_PORT=8000

# React frontend env (Vite prefix required)
VITE_API_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════
# Legacy / Optional
# ═══════════════════════════════════════════════════════════════

# Testnet RPC (Base Sepolia)
RPC_URL=https://sepolia.base.org

# x402 Server
SERVER_PORT=4020
SERVER_HOST=127.0.0.1

# Agent Configuration
AGENT_BUDGET_USD=50
AGENT_MAX_PER_REQUEST=10
AGENT_WHITELIST=127.0.0.1,localhost
