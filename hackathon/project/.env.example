# Example environment variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Testnet RPC (Base Sepolia)
RPC_URL=https://sepolia.base.org

# For local testing, no private key needed
# In production, use CAW Session Key, never raw private key
# PRIVATE_KEY=your_private_key_here  # NEVER commit this

# CAW Configuration (Mock mode for now)
CAW_MODE=mock
CAW_ORG_ID=your_org_id
CAW_API_KEY=your_api_key  # NEVER commit this

# x402 Server
SERVER_PORT=4020
SERVER_HOST=127.0.0.1

# Agent Configuration
AGENT_BUDGET_USD=50
AGENT_MAX_PER_REQUEST=10
AGENT_WHITELIST=127.0.0.1,localhost
